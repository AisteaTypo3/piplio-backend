{
    "name": "aistea/piplio-backend",
    "type": "typo3-cms-extension",
    "description": "Piplio backend: word list management API for the MathQuest learning app",
    "license": ["GPL-2.0-or-later"],
    "authors": [
        {
            "name": "Yannick Aister",
            "email": "info.aister@gmail.com"
        }
    ],
    "require": {
        "typo3/cms-backend": "^14",
        "typo3/cms-core": "^14",
        "typo3/cms-extbase": "^14",
        "typo3/cms-fluid": "^14",
        "typo3/cms-frontend": "^14",
        "phpoffice/phpspreadsheet": "^3.0"
    },
    "autoload": {
        "psr-4": {
